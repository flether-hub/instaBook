# LLM API Authentication
# The app will check for these in order: DEEPSEEK_API_KEY, QWEN_API_KEY, API_KEY, VITE_API_KEY, LLM_API_KEY
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"
QWEN_API_KEY="YOUR_QWEN_API_KEY"
API_KEY=
LLM_API_KEY=

# API Endpoint (defaults to DashScope if not set)
# For DeepSeek official: https://api.deepseek.com/v1/chat/completions
API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# Admin configuration for Cloudflare Function login
ADMIN_PASSWORD="YOUR_ADMIN_PASSWORD"

